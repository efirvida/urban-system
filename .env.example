# Geoapify API Key — para calcular matriz de distancias reales (rutas por carretera)
# Obtener en: https://myprojects.geoapify.com
# Free tier: 3,000 créditos/día (~6 matrices de 48 puntos)
# Si no se configura, el frontend usa OSRM + Haversine como fallback
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# OpenRouteService API Key — proveedor alternativo de matriz de distancias
# Obtener en: https://openrouteservice.org/dev/#/signup
# Free tier: 5,000 elementos/request (~70 puntos por matriz)
# Opcional — si no se configura, el consenso opera con Geoapify + OSRM
ORS_API_KEY=your_ors_api_key_here
